{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/profile/layout,_N_T_/profile/requests/layout,_N_T_/profile/requests/page,_N_T_/profile/requests/"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/profile/requests/__PAGE__",
    "/profile/requests",
    "/profile",
    "/_index",
    "/_head"
  ]
}